#!/usr/bin/env bash

set -euo pipefail

# This script opens nushell by default, or runs an explicit command inside a running workspace container.

# This finds the repo root so the script can reach shared helpers.
SCRIPT_DIR="$(cd "$(dirname "$0")" && pwd)"
ROOT="$(cd "$SCRIPT_DIR/../../.." && pwd)"
source "$ROOT/lib/shell/shared/common.sh"

# This loads the saved workspace list before the script picks or validates a workspace.
hermes_load_workspaces

# This chooses the workspace first, then treats any remaining words as the in-container command.
if [[ $# -eq 0 ]]; then
  workspace="$(hermes_pick_workspace)"
  command=("$HERMES_AGENT_SHELL_COMMAND")
else
  workspace="$1"
  hermes_validate_workspace_name "$workspace"
  hermes_workspace_offset "$workspace" >/dev/null
  shift

  if [[ $# -eq 0 ]]; then
    command=("$HERMES_AGENT_SHELL_COMMAND")
  else
    command=("$@")
  fi
fi

# This looks for the chosen workspace container after the command mode is decided.
container_name="$(hermes_running_container "$workspace")"

# This gives a clear message when the chosen workspace is not running yet.
if [[ -z "$container_name" ]]; then
  printf 'No running Hermes Agent container found for %s. Run scripts/agent/shared/hermes-agent-run first.\n' "$workspace" >&2
  exit 1
fi

# This opens nushell by default, or runs the explicit command vector when one was provided.
hermes_exec_podman_interactive_command exec "$container_name" "${command[@]}"
