#!/usr/bin/env bash

set -euo pipefail

# This script keeps the container alive and starts Hermes services only after setup is complete.

gateway_pid=""
dashboard_pid=""

# This prints entrypoint messages in one predictable format.
log() {
  printf '%s\n' "$*" >&2
}

# This treats setup as complete only when the usual Hermes config files are present.
setup_is_complete() {
  [[ -s "${HERMES_HOME}/config.toml" ]] && [[ -s "${HERMES_HOME}/.env" ]]
}

# This starts the Hermes gateway in the background and records its pid.
start_gateway() {
  hermes gateway run &
  gateway_pid="$!"
}

# This starts the Hermes dashboard in the background and records its pid.
start_dashboard() {
  hermes dashboard --host 0.0.0.0 --port "$HERMES_AGENT_DASHBOARD_PORT" --no-open --insecure &
  dashboard_pid="$!"
}

# This reaps background services and forwards container shutdown cleanly.
stop_services() {
  if [[ -n "$gateway_pid" ]] && kill -0 "$gateway_pid" 2>/dev/null; then
    kill "$gateway_pid" 2>/dev/null || true
  fi

  if [[ -n "$dashboard_pid" ]] && kill -0 "$dashboard_pid" 2>/dev/null; then
    kill "$dashboard_pid" 2>/dev/null || true
  fi

  wait 2>/dev/null || true
}

# This keeps the container alive in a safe idle mode until setup is finished.
idle_until_setup() {
  log "Hermes setup is incomplete. Skipping gateway and dashboard startup until ${HERMES_HOME}/config.toml and ${HERMES_HOME}/.env exist."

  # This polls for the usual setup files so services start as soon as setup finishes.
  while ! setup_is_complete; do
    sleep 5
  done
}

# This fails early if either service dies during the startup window.
wait_for_startup_stability() {
  local attempt=""

  for attempt in 1 2 3 4 5; do
    if ! kill -0 "$gateway_pid" 2>/dev/null; then
      log 'Hermes gateway exited during startup.'
      return 1
    fi

    if ! kill -0 "$dashboard_pid" 2>/dev/null; then
      log 'Hermes dashboard exited during startup.'
      return 1
    fi

    sleep 1
  done
}

# This keeps PID 1 running only while both managed services are still alive.
wait_for_services() {
  while kill -0 "$gateway_pid" 2>/dev/null && kill -0 "$dashboard_pid" 2>/dev/null; do
    sleep 1
  done

  log 'Hermes services stopped after startup.'
  return 1
}

# This runs setup-safe mode or the managed Hermes services depending on config state.
main() {
  trap 'stop_services; exit 143' INT TERM
  trap 'stop_services' EXIT

  if ! setup_is_complete; then
    idle_until_setup
  fi

  start_gateway
  start_dashboard
  wait_for_startup_stability
  wait_for_services
}

main "$@"
