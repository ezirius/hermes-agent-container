#!/usr/bin/env bash

set -euo pipefail

# This script builds a fresh Hermes Agent image from the saved repo settings.

# This finds the repo root so the script can reach shared helpers and config.
SCRIPT_DIR="$(cd "$(dirname "$0")" && pwd)"
ROOT="$(cd "$SCRIPT_DIR/../../.." && pwd)"
source "$ROOT/lib/shell/shared/common.sh"

# This keeps the build entrypoint simple and predictable.
if [[ $# -ne 0 ]]; then
  printf 'This script takes no arguments.\n' >&2
  exit 1
fi

# This stops the build if the checkout is not fully committed and clean.
hermes_require_clean_committed_checkout "$ROOT"

# This makes a unique image name so each successful build can be found later.
printf -v build_suffix '%03d' "$(( $$ % 1000 ))"
timestamp="$(/bin/date +"%Y%m%d-%H%M%S")-$build_suffix"
image_name="$HERMES_AGENT_IMAGE_BASENAME-$HERMES_AGENT_VERSION-$timestamp"
iidfile_path="$(mktemp)"
before_dangling_images_path="$(mktemp)"
after_dangling_images_path="$(mktemp)"
new_dangling_images_path="$(mktemp)"

# This removes the temporary iidfile after the build succeeds or fails.
cleanup() {
  rm -f "$iidfile_path"
  rm -f "$before_dangling_images_path" "$after_dangling_images_path" "$new_dangling_images_path"
}

trap cleanup EXIT

# This snapshots current dangling image ids so cleanup can target only the dangling image created by this build.
podman images --filter dangling=true --format '{{.ID}}' | sort -u >"$before_dangling_images_path"

# This lets Podman stream its normal build output while saving the final image id for later.
podman build \
  --build-arg HERMES_AGENT_UPSTREAM_IMAGE="$HERMES_AGENT_UPSTREAM_IMAGE" \
  --build-arg HERMES_AGENT_RELEASE_TAG="$HERMES_AGENT_RELEASE_TAG" \
  --iidfile "$iidfile_path" \
  -f "$ROOT/config/containers/shared/Containerfile" \
  -t "$image_name" \
  "$ROOT"

# This reads the saved image id after Podman finishes streaming the build output.
image_id="$(<"$iidfile_path")"

printf 'Image ID: %s\n' "$image_id"

# This removes only the exact new dangling builder image created by this build, leaving every other image untouched.
podman images --filter dangling=true --format '{{.ID}}' | sort -u >"$after_dangling_images_path"
comm -13 "$before_dangling_images_path" "$after_dangling_images_path" >"$new_dangling_images_path"

if [[ "$(grep -cve '^$' "$new_dangling_images_path")" == '1' ]]; then
  dangling_image_id="$(<"$new_dangling_images_path")"
  dangling_image_id="${dangling_image_id//$'\n'/}"

  if [[ -n "$dangling_image_id" && "$dangling_image_id" != "$image_id" ]]; then
    podman rmi "$dangling_image_id" >/dev/null 2>&1 || true
  fi
fi
