#!/usr/bin/env bash

set -euo pipefail

# This script starts a saved workspace container, then opens Hermes.

# This finds the repo root so the script can reach shared helpers.
SCRIPT_DIR="$(cd "$(dirname "$0")" && pwd)"
ROOT="$(cd "$SCRIPT_DIR/../../.." && pwd)"
source "$ROOT/lib/shell/shared/common.sh"

# This loads the saved workspace list before the script picks or validates a workspace.
hermes_load_workspaces

# This command either uses the picker or accepts one direct workspace name.
while [[ $# -gt 0 ]]; do
  case "$1" in
    --)
      shift
      break
      ;;
    -*)
      printf 'Unsupported option: %s\n' "$1" >&2
      exit 1
      ;;
    *)
      break
      ;;
  esac
done

if [[ $# -gt 1 ]]; then
  printf 'This script takes zero or one argument: [workspace].\n' >&2
  exit 1
fi

# This warns about stale release pins before image lookup and container work begin.
hermes_warn_if_pinned_version_is_stale

# This finds the newest local image the run script is allowed to use.
image_name="$(hermes_latest_image)"

if [[ -z "$image_name" ]]; then
  printf 'No built Hermes Agent image found. Run scripts/agent/shared/hermes-agent-build first.\n' >&2
  exit 1
fi

# This chooses the workspace from the argument when present, otherwise from the picker.
if [[ $# -eq 1 ]]; then
  workspace="$1"
  hermes_validate_workspace_name "$workspace"
else
  workspace="$(hermes_pick_workspace)"
fi

# This rejects broad base paths before any host directory or ownership work.
hermes_validate_safe_host_base_path
hermes_validate_safe_host_dirnames

# This builds the host paths and names around the selected workspace.
host_home="$(hermes_host_home_dir "$workspace")"
host_workspace="$(hermes_host_workspace_dir "$workspace")"
old_containers="$(hermes_workspace_containers "$workspace")"
old_pods="$(hermes_workspace_pods "$workspace")"

host_port="$(hermes_workspace_published_port "$workspace")"
container_name="$(hermes_container_name "$image_name" "$workspace")"
pod_name="$container_name"
dashboard_url="$(hermes_workspace_published_url "$workspace")"
reuse_container=0
reuse_pod=0
runtime_created=0
runtime_started=0
matching_container=""
recreated_exact_match_container=0
runtime_userns_args=(--userns keep-id)

# This rejects symlinked managed mount paths before creation or ownership repair.
hermes_reject_symlinked_managed_path "$host_home"
hermes_reject_symlinked_managed_path "$host_workspace"

# This checks whether an existing pod publishes the dashboard on the expected host loopback port.
dashboard_port_matches_expected() {
  local published pod_bindings expected_binding

  published="$(podman port "$pod_name" "$HERMES_AGENT_DASHBOARD_PORT/tcp" 2>/dev/null || true)"
  if [[ "$published" == "127.0.0.1:$host_port" ]]; then
    return 0
  fi

  pod_bindings="$(podman pod inspect --format '{{json .InfraConfig.PortBindings}}' "$pod_name" 2>/dev/null || true)"
  if [[ "$pod_bindings" == *'"HostIp":"0.0.0.0"'* || "$pod_bindings" == *'"HostIp":""'* ]]; then
    return 1
  fi

  expected_binding="\"$HERMES_AGENT_DASHBOARD_PORT/tcp\":[{\"HostIp\":\"127.0.0.1\",\"HostPort\":\"$host_port\"}]"
  [[ "$pod_bindings" == *"$expected_binding"* ]]
}

# This creates the workspace pod and publishes the dashboard on host loopback.
create_pod() {
  podman pod create "${runtime_userns_args[@]}" --name "$pod_name" -p "127.0.0.1:$host_port:$HERMES_AGENT_DASHBOARD_PORT" >/dev/null
}

# This checks whether a pod with the exact name already exists.
pod_exists() {
  local pod_name="$1"
  local matched_pod

  matched_pod="$(podman pod ps --format '{{.Name}}' --filter "name=$(hermes_container_name_regex "$pod_name")" | head -n 1)"
  [[ "$matched_pod" == "$pod_name" ]]
}

# This checks whether the exact runtime container name already exists in any state.
exact_container_exists() {
  local matched_container

  matched_container="$(podman ps -aq --format '{{.Names}}' --filter "name=$(hermes_container_name_regex "$container_name")" | head -n 1)"
  [[ "$matched_container" == "$container_name" ]]
}

# This creates the runtime container with the current image, mounts, and dashboard command.
create_container() {
  local container_id

  container_id="$(podman run -d \
    --name "$container_name" \
    --pod "$pod_name" \
    --workdir "$HERMES_AGENT_CONTAINER_WORKSPACE" \
    -v "$host_home:$HERMES_AGENT_CONTAINER_HOME" \
    -v "$host_workspace:$HERMES_AGENT_CONTAINER_WORKSPACE" \
    "$image_name" \
    dashboard --host 0.0.0.0 --port "$HERMES_AGENT_DASHBOARD_PORT" --no-open --insecure)"
  runtime_created=1
  printf 'Container ID: %s\n' "$container_id"
}

# This makes sure the host folders exist before the container is started.
mkdir -p "$host_home" "$host_workspace"

# This keeps root-launched runs from leaving host paths owned by root.
if [[ "$(id -u)" == '0' ]]; then
  chown -R "$(hermes_host_uid):$(hermes_host_gid)" "$host_home" "$host_workspace"
  runtime_userns_args=()
fi

# This checks whether the newest image already has a matching workspace container.
while IFS= read -r old_container; do
  [[ -n "$old_container" ]] || continue
  if [[ "$old_container" == "$container_name" ]]; then
    reuse_container=1
  fi
done <<< "$old_containers"

# This checks whether the newest image already has a matching workspace pod.
if pod_exists "$pod_name"; then
  reuse_pod=1
fi

# This checks whether the exact matching container is already running.
matching_container="$(podman ps --format '{{.Names}}' --filter "name=$(hermes_container_name_regex "$container_name")" | head -n 1)"
# This forces a replacement when an exact pod exposes the dashboard with the wrong publish contract.
if [[ "$reuse_pod" == "1" ]] && ! dashboard_port_matches_expected; then
  podman rm -f "$container_name" >/dev/null 2>&1 || true
  podman pod rm -f "$pod_name" >/dev/null 2>&1 || true
  reuse_container=0
  reuse_pod=0
  matching_container=""
fi

# This clears exact-name stale mount conflicts before creating the replacement container.
if exact_container_exists && ! hermes_container_workspace_matches "$container_name" "$workspace"; then
  podman rm -f "$container_name" >/dev/null 2>&1 || true
  reuse_container=0
  matching_container=""
fi

# This creates a new container when needed, or reuses the right old one when it already exists.
if [[ "$reuse_container" != "1" ]]; then
  if [[ "$reuse_pod" != "1" ]]; then
    create_pod
  fi
  create_container
elif [[ "$matching_container" != "$container_name" ]]; then
  podman start "$container_name" >/dev/null 2>&1 || true
  runtime_started=1
fi

while true; do
  # This waits a little so the script only attaches after the container is really running.
  if ! hermes_wait_for_running_container "$container_name"; then
    if [[ "$reuse_container" == "1" && "$recreated_exact_match_container" != "1" ]]; then
      podman rm -f "$container_name" >/dev/null 2>&1 || true
      podman pod rm -f "$pod_name" >/dev/null 2>&1 || true
      create_pod
      create_container
      reuse_container=0
      recreated_exact_match_container=1
      continue
    fi

    printf 'Hermes Agent container failed to stay running: %s\n' "$container_name" >&2
    hermes_print_container_startup_diagnostics "$container_name"
    exit 1
  fi

  # This removes older workspace containers only after the replacement proved it stayed up.
  if [[ "$reuse_container" != "1" ]]; then
    while IFS= read -r old_container; do
      [[ -n "$old_container" ]] || continue
      [[ "$old_container" == "$container_name" ]] && continue
      podman rm -f "$old_container" >/dev/null 2>&1 || true
      podman pod rm -f "$old_container" >/dev/null 2>&1 || true
    done <<< "$old_containers"

    while IFS= read -r old_pod; do
      [[ -n "$old_pod" ]] || continue
      [[ "$old_pod" == "$pod_name" ]] && continue
      podman pod rm -f "$old_pod" >/dev/null 2>&1 || true
    done <<< "$old_pods"
  fi

  # This opens the dashboard only when this run created or started the runtime.
  if [[ "$runtime_created" == "1" || "$runtime_started" == "1" ]]; then
    if hermes_wait_for_published_url "$dashboard_url"; then
      hermes_open_published_url_detached "$dashboard_url"
    fi
  fi

  # This recreates a poisoned exact-match container once before giving up on attach.
  if ! hermes_wait_for_stable_running_container "$container_name"; then
    if [[ "$reuse_container" == "1" && "$recreated_exact_match_container" != "1" ]]; then
      podman rm -f "$container_name" >/dev/null 2>&1 || true
      podman pod rm -f "$pod_name" >/dev/null 2>&1 || true
      create_pod
      create_container
      reuse_container=0
      recreated_exact_match_container=1
      continue
    fi

    printf 'Hermes Agent container stopped before attach: %s\n' "$container_name" >&2
    hermes_print_container_startup_diagnostics "$container_name"
    exit 1
  fi

  break
done

hermes_exec_podman_interactive_command exec --workdir "$HERMES_AGENT_CONTAINER_WORKSPACE" "$container_name" "$HERMES_AGENT_CHAT_COMMAND"
