#!/usr/bin/env bash

set -euo pipefail

# This script starts one saved workspace container and opens Hermes inside it.

# This finds the repo root so the script can reach shared helpers.
SCRIPT_DIR="$(cd "$(dirname "$0")" && pwd)"
ROOT="$(cd "$SCRIPT_DIR/../../.." && pwd)"
source "$ROOT/lib/shell/shared/common.sh"

# This checks the simple entry rules and loads the saved workspace list.
hermes_require_no_args "$@"
hermes_load_workspaces

# This finds the newest local image the run script is allowed to use.
image_name="$(hermes_latest_image)"

if [[ -z "$image_name" ]]; then
  printf 'No built Hermes Agent image found. Run scripts/agent/shared/hermes-agent-build first.\n' >&2
  exit 1
fi

# This chooses the workspace and builds the host paths and names around it.
workspace="$(hermes_pick_workspace)"
port_offset="$(hermes_workspace_offset "$workspace")"
host_home="$HERMES_AGENT_BASE_PATH/$workspace/$HERMES_AGENT_HOST_HOME_DIRNAME"
host_workspace="$HERMES_AGENT_BASE_PATH/$workspace/$HERMES_AGENT_HOST_WORKSPACE_DIRNAME"
old_containers="$(hermes_workspace_containers "$workspace")"

image_suffix="${image_name#$HERMES_AGENT_IMAGE_BASENAME-}"
host_port=$((HERMES_AGENT_DASHBOARD_PORT + port_offset))
container_name="$HERMES_AGENT_IMAGE_BASENAME-$workspace-$image_suffix"
dashboard_url="http://127.0.0.1:$host_port"
reuse_existing=0
matching_running_container=""

# This makes sure the host folders exist before the container is started.
mkdir -p "$host_home" "$host_workspace"

# This checks whether the newest image already has a matching workspace container.
while IFS= read -r old_container; do
  [[ -n "$old_container" ]] || continue
  if [[ "$old_container" == "$container_name" ]]; then
    reuse_existing=1
    break
  fi
done <<< "$old_containers"

# This checks whether that exact matching container is already running.
matching_running_container="$(podman ps --format '{{.Names}}' --filter "name=$(hermes_container_name_regex "$container_name")" | head -n 1)"

# This creates a new container when needed, or reuses the right old one when it already exists.
if [[ "$reuse_existing" != "1" ]]; then
  podman run -d \
    --name "$container_name" \
    -p "$host_port:$HERMES_AGENT_DASHBOARD_PORT" \
    -v "$host_home:$HERMES_AGENT_CONTAINER_HOME" \
    -v "$host_workspace:$HERMES_AGENT_CONTAINER_WORKSPACE" \
    "$image_name"

elif [[ "$matching_running_container" != "$container_name" ]]; then
  # This starts the matching stopped container instead of making a duplicate one.
  podman start "$container_name" >/dev/null
fi

# This waits a little so the script only attaches after the container is really running.
if ! hermes_wait_for_running_container "$container_name"; then
  printf 'Hermes Agent container failed to stay running: %s\n' "$container_name" >&2
  exit 1
fi

# This removes older workspace containers only after the replacement proved it stayed up.
if [[ "$reuse_existing" != "1" ]]; then
  while IFS= read -r old_container; do
    [[ -n "$old_container" ]] || continue
    [[ "$old_container" == "$container_name" ]] && continue
    podman rm -f "$old_container" >/dev/null 2>&1 || true
  done <<< "$old_containers"
fi

# This waits a moment, opens the dashboard on the host, and then attaches to Hermes.
sleep 2
hermes_open_dashboard "$dashboard_url"
hermes_exec_podman_interactive_command exec "$container_name" "$HERMES_AGENT_CHAT_COMMAND"
