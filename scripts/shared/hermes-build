#!/usr/bin/env bash
set -euo pipefail

SCRIPT_DIR="$(cd "$(dirname "$0")" && pwd)"
ROOT="$(cd "$SCRIPT_DIR/../.." && pwd)"
source "$ROOT/lib/shell/common.sh"

run_build_git_guards() {
  local lane="$1"

  if [[ "$lane" == "$HERMES_LANE_PRODUCTION" && -z "${HERMES_SKIP_PRODUCTION_GUARDS:-}" ]]; then
    require_canonical_main_checkout "$ROOT"
  fi

  require_clean_git "$ROOT"

  if [[ "$lane" == "$HERMES_LANE_PRODUCTION" && -z "${HERMES_SKIP_PRODUCTION_GUARDS:-}" ]]; then
    require_main_pushed "$ROOT"
  fi
}

rerun_post_pin_update_guards() {
  local lane="$1"

  if [[ "$lane" == "$HERMES_LANE_PRODUCTION" && -z "${HERMES_SKIP_PRODUCTION_GUARDS:-}" ]]; then
    require_canonical_main_checkout "$ROOT"
    require_main_pushed "$ROOT"
  fi
}

if [[ ${1-} == "--help" ]]; then
  show_help "Usage: $(basename "$0") $(lane_usage_text) [upstream]

Build a Hermes image for one lane and upstream version.

If the lane is omitted, the wrapper prompts for the configured production or test lane.
If [upstream] is omitted, the wrapper prompts for an upstream version.

Arguments:
- $(lane_usage_text)         optional lane selector
- [upstream]                 exact stable upstream version tag, 'latest', or 'main'
-                             if omitted, the script prompts with 'main' and
-                             the currently available upstream release tags

The image gets one immutable tag only:
  <lane>-<upstream>-<wrapper>-<commitstamp>

Examples:
  production-2026.4.8-main-20260408-153210-ab12cd3
  test-main-improve-production-and-testing-20260408-153210-ab12cd3

Production builds must run from the canonical main checkout. Test builds may
run from the canonical main checkout or a worktree.

The build checks whether the pinned Ubuntu LTS and Node LTS versions in
config/shared/tool-versions.conf are behind the current latest LTS releases and
prompts before continuing if an update is available."
fi

if [[ $# -gt 2 ]]; then
  usage_error "$(basename "$0") $(lane_usage_text) [upstream]"
fi

if [[ $# -ge 1 ]]; then
  LANE="$1"
else
  LANE="$(prompt_select_option "Select a build lane" "$HERMES_LANE_PRODUCTION" "$HERMES_LANE_TEST")"
fi

RAW_REF="${2:-}"

validate_lane "$LANE"
run_build_git_guards "$LANE"

if [[ -z "$RAW_REF" ]]; then
  require_podman
  OPTION_LABELS=("$HERMES_UPSTREAM_MAIN_SELECTOR")
  OPTION_VALUES=("$HERMES_UPSTREAM_MAIN_SELECTOR")
  RELEASE_OPTIONS="$(list_upstream_release_options)" || fail "failed to list upstream Hermes releases"
  while IFS=$'\t' read -r label value; do
    [[ -n "$label" && -n "$value" ]] || continue
    OPTION_LABELS+=("$label")
    OPTION_VALUES+=("$value")
  done <<< "$RELEASE_OPTIONS"
  SELECTED_LABEL="$(prompt_select_option "Select upstream Hermes version" "${OPTION_LABELS[@]}")"
  for i in "${!OPTION_LABELS[@]}"; do
    if [[ "${OPTION_LABELS[i]}" == "$SELECTED_LABEL" ]]; then
      RAW_REF="${OPTION_VALUES[i]}"
      break
    fi
  done
  [[ -n "$RAW_REF" ]] || fail "failed to resolve selected upstream Hermes version"
fi

validate_upstream_selector "$RAW_REF"

require_podman

PINS_MUTATED=0

if [[ -z "${HERMES_SKIP_UBUNTU_LTS_CHECK:-}" ]]; then
  LATEST_UBUNTU_LTS="$(resolve_latest_pinned_version_or_current "Ubuntu LTS" "$HERMES_UBUNTU_LTS_VERSION" latest_ubuntu_lts_version)"
else
  LATEST_UBUNTU_LTS="$HERMES_UBUNTU_LTS_VERSION"
fi

if [[ "$LATEST_UBUNTU_LTS" != "$HERMES_UBUNTU_LTS_VERSION" ]]; then
  UBUNTU_ACTION="$(prompt_select_option "Ubuntu LTS update available (pinned: $HERMES_UBUNTU_LTS_VERSION, latest: $LATEST_UBUNTU_LTS)" "keep current pin" "update pin and continue" "cancel")"
  case "$UBUNTU_ACTION" in
    "keep current pin")
      ;;
    "update pin and continue")
      update_config_assignment "$(tool_versions_config_path)" HERMES_UBUNTU_LTS_VERSION "$LATEST_UBUNTU_LTS"
      HERMES_UBUNTU_LTS_VERSION="$LATEST_UBUNTU_LTS"
      PINS_MUTATED=1
      ;;
    "cancel")
      exit 1
      ;;
  esac
fi

if [[ -z "${HERMES_SKIP_NODE_LTS_CHECK:-}" ]]; then
  LATEST_NODE_LTS="$(resolve_latest_pinned_version_or_current "Node LTS" "$HERMES_NODE_LTS_VERSION" latest_node_lts_version)"
else
  LATEST_NODE_LTS="$HERMES_NODE_LTS_VERSION"
fi

if [[ "$LATEST_NODE_LTS" != "$HERMES_NODE_LTS_VERSION" ]]; then
  NODE_ACTION="$(prompt_select_option "Node LTS update available (pinned: $HERMES_NODE_LTS_VERSION, latest: $LATEST_NODE_LTS)" "keep current pin" "update pin and continue" "cancel")"
  case "$NODE_ACTION" in
    "keep current pin")
      ;;
    "update pin and continue")
      update_config_assignment "$(tool_versions_config_path)" HERMES_NODE_LTS_VERSION "$LATEST_NODE_LTS"
      HERMES_NODE_LTS_VERSION="$LATEST_NODE_LTS"
      PINS_MUTATED=1
      ;;
    "cancel")
      exit 1
      ;;
  esac
fi

if [[ "$PINS_MUTATED" == "1" ]]; then
  rerun_post_pin_update_guards "$LANE"
fi

SELECTION="$(resolve_hermes_selection "$RAW_REF")"
RESOLVED_REF="${SELECTION%%$'\t'*}"
BUILD_REF="${SELECTION#*$'\t'}"
WRAPPER_CONTEXT="$(current_wrapper_context "$ROOT")"
LOCAL_BUILD_FINGERPRINT="$(local_build_fingerprint)"
COMMITSTAMP="$(wrapper_build_commitstamp "$ROOT" "$LOCAL_BUILD_FINGERPRINT")"

TAG_ARGS=()
while IFS= read -r tag; do
  TAG_ARGS+=(-t "$HERMES_IMAGE_NAME:$tag")
done < <(build_tags_for_lane "$LANE" "$RESOLVED_REF" "$WRAPPER_CONTEXT" "$COMMITSTAMP")

echo "==> Building Hermes image"
echo "==> Upstream repo: $HERMES_REPO_URL"
echo "==> Upstream ref:  $RESOLVED_REF"
echo "==> Git ref:       $BUILD_REF"
echo "==> Lane:          $LANE"
echo "==> Wrapper:       $WRAPPER_CONTEXT"
echo "==> Commit stamp:  $COMMITSTAMP"
echo "==> Ubuntu LTS:    $HERMES_UBUNTU_LTS_VERSION"
echo "==> Node LTS:      $HERMES_NODE_LTS_VERSION"
echo "==> Local build fingerprint: $LOCAL_BUILD_FINGERPRINT"
echo "==> Tags:"
for tag in "${TAG_ARGS[@]}"; do
  echo "     ${tag#-t }"
done

podman build \
  --pull=always \
  "${TAG_ARGS[@]}" \
  --label "${HERMES_LABEL_NAMESPACE}.repo_url=$HERMES_REPO_URL" \
  --label "$HERMES_LABEL_UPSTREAM=$RESOLVED_REF" \
  --label "$(hermes_upstream_ref_label_key)=$BUILD_REF" \
  --label "$(hermes_build_fingerprint_label_key)=$LOCAL_BUILD_FINGERPRINT" \
  --label "$HERMES_LABEL_LANE=$LANE" \
  --label "$HERMES_LABEL_WRAPPER=$WRAPPER_CONTEXT" \
  --label "$HERMES_LABEL_COMMITSTAMP=$COMMITSTAMP" \
  --build-arg "HERMES_WRAPPER_LANE=$LANE" \
  --build-arg "HERMES_WRAPPER_UPSTREAM=$RESOLVED_REF" \
  --build-arg "HERMES_WRAPPER_UPSTREAM_REF=$BUILD_REF" \
  --build-arg "HERMES_WRAPPER_CONTEXT=$WRAPPER_CONTEXT" \
  --build-arg "HERMES_WRAPPER_COMMITSTAMP=$COMMITSTAMP" \
  --build-arg "HERMES_REPO_URL=$HERMES_REPO_URL" \
  --build-arg "HERMES_REF=$BUILD_REF" \
  --build-arg "UBUNTU_VERSION=$HERMES_UBUNTU_LTS_VERSION" \
  --build-arg "NODE_LTS_VERSION=$HERMES_NODE_LTS_VERSION" \
  --build-arg "HERMES_CONTAINER_RUNTIME_HOME=$HERMES_CONTAINER_RUNTIME_HOME" \
  --build-arg "HERMES_CONTAINER_WORKSPACE_DIR=$HERMES_CONTAINER_WORKSPACE_DIR" \
  -f "$ROOT/config/containers/Containerfile.wrapper" \
  "$ROOT"
echo "==> Hermes image build complete"
