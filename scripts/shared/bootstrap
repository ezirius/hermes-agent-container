#!/usr/bin/env bash
set -euo pipefail

SCRIPT_DIR="$(cd "$(dirname "$0")" && pwd)"
ROOT="$(cd "$SCRIPT_DIR/../.." && pwd)"
source "$ROOT/lib/shell/common.sh"

if [[ $# -lt 1 ]]; then
  usage_error "$(basename "$0") requires at least 1 argument: <workspace-name> [hermes args...]"
fi

WORKSPACE="$1"
shift

"$SCRIPT_DIR/hermes-build"
"$SCRIPT_DIR/hermes-upgrade"
"$SCRIPT_DIR/hermes-start" "$WORKSPACE"
exec "$SCRIPT_DIR/hermes-open" "$WORKSPACE" "$@"
