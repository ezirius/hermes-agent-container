#!/usr/bin/env bash
set -euo pipefail

SCRIPT_DIR="$(cd "$(dirname "$0")" && pwd)"
ROOT="$(cd "$SCRIPT_DIR/../.." && pwd)"
source "$ROOT/lib/shell/common.sh"

if [[ ${1-} == "--help" ]]; then
  show_help "Usage: $(basename "$0") [<workspace-name>] [extra podman args...]
       $(basename "$0") -- [extra podman args...]

Stream container logs for one workspace.

Arguments:
- <workspace-name>           optional workspace name
- [extra podman args...]     forwarded to podman logs"
fi

if [[ $# -gt 0 && "$1" != "--" ]]; then
  WORKSPACE="$(resolve_workspace_argument "$1")"
  shift
else
  WORKSPACE="$(resolve_workspace_argument '')"
  if [[ ${1-} == "--" ]]; then
    shift
  fi
fi

require_podman
TARGET_ROW="$(pick_workspace_target "$WORKSPACE" container)"
IFS=$'\t' read -r _ HERMES_CONTAINER_NAME _ _ _ _ _ <<< "$TARGET_ROW"

container_exists || fail "container not found: $HERMES_CONTAINER_NAME"
podman logs "$HERMES_CONTAINER_NAME" "$@"
