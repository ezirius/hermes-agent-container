#!/usr/bin/env bash
set -euo pipefail

SCRIPT_DIR="$(cd "$(dirname "$0")" && pwd)"
ROOT="$(cd "$SCRIPT_DIR/../.." && pwd)"
source "$ROOT/lib/shell/common.sh"

if [[ ${1-} == "--help" ]]; then
  show_help "Usage: $(basename "$0") <workspace-name> [hermes args...]

Open Hermes by execing into the running container for one workspace.

Arguments:
- <workspace-name>           workspace name"
fi

if [[ $# -lt 1 ]]; then
  usage_error "$(basename "$0") requires at least 1 argument: <workspace-name> [hermes args...]"
fi

WORKSPACE="$1"
shift 1

require_workspace_name "$WORKSPACE"

if [[ $# -ge 2 && ( "$1" == "production" || "$1" == "test" ) ]]; then
  LANE="$1"
  REF="$2"
  shift 2
  resolve_build_target "$WORKSPACE" "$LANE" "$REF"
else
  TARGET_ROW="$(pick_workspace_target "$WORKSPACE" container)"
  IFS=$'\t' read -r HERMES_CONTAINER_NAME _ _ _ _ _ <<< "$TARGET_ROW"
fi

container_exists || fail "container not found: $HERMES_CONTAINER_NAME (run hermes-build and hermes-start first)"

RUN_ARGS=(--workdir /workspace "$HERMES_CONTAINER_NAME" hermes)
RUN_ARGS+=("$@")
exec_podman_interactive_command exec "${RUN_ARGS[@]}"
