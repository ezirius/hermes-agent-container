#!/usr/bin/env bash
set -euo pipefail

SCRIPT_DIR="$(cd "$(dirname "$0")" && pwd)"
ROOT="$(cd "$SCRIPT_DIR/../.." && pwd)"
source "$ROOT/lib/shell/common.sh"

if [[ ${1-} == "--help" ]]; then
  show_help "Usage: $(basename "$0") <workspace-name> [hermes args...]
       $(basename "$0") <workspace-name> <lane> <upstream> [hermes args...]

Start or reuse the Hermes Gateway container for one workspace.

Arguments:
- <workspace-name>           required workspace name under HERMES_BASE_ROOT

Container naming:
  hermes-agent-<workspace>-<lane>-<upstream>-<wrapper>

The wrapper mounts:
- <workspace>/hermes-home      -> /opt/data
- <workspace>/hermes-workspace -> /workspace/hermes-workspace

The image uses an upstream-style entrypoint. Hermes reads /opt/data/.env and
/opt/data/config.yaml when the gateway process starts. The container is created
with restart policy unless-stopped so crashes and host reboots recover
automatically.

Image naming:
  hermes-agent-local:<lane>-<upstream>-<wrapper>-<commitstamp>

Build labels (ref, lane, wrapper, fingerprint) are automatically injected from the image.

In explicit mode, the target image is resolved for the current wrapper context."
fi

if [[ $# -lt 1 ]]; then
  usage_error "$(basename "$0") requires at least 1 argument: <workspace-name> [hermes args...]"
fi

WORKSPACE="$1"
shift 1
TARGET_KIND="explicit"

require_workspace_name "$WORKSPACE"
require_podman

if [[ $# -ge 2 && ( "$1" == "production" || "$1" == "test" ) ]]; then
  LANE="$1"
  REF="$2"
  shift 2
  resolve_start_target "$WORKSPACE" "$LANE" "$REF"
else
  TARGET_ROW="$(pick_workspace_target "$WORKSPACE" target)"
  IFS=$'\t' read -r TARGET_KIND _ LANE REF HERMES_WRAPPER_CONTEXT HERMES_COMMITSTAMP _ <<< "$TARGET_ROW"
  resolve_start_target "$WORKSPACE" "$LANE" "$REF" "$HERMES_WRAPPER_CONTEXT" "$HERMES_COMMITSTAMP"
fi

if [[ "$LANE" != "production" && "$LANE" != "test" ]]; then
  fail "lane must be 'production' or 'test', got: $LANE"
fi

if [[ "$REF" == "latest" || "$REF" == "main" ]]; then
  : # valid
elif [[ "$REF" =~ ^[v]?[0-9]+[.][0-9]+[.][0-9]+ ]]; then
  : # semver-style version
elif [[ "$REF" =~ ^[a-zA-Z0-9._-]+$ ]]; then
  : # generic tag-like ref
else
  fail "ref must be 'latest', 'main', or a version string (e.g. 0.7.0, v0.21.0), got: $REF"
fi

ensure_workspace_dirs
migrate_legacy_workspace_layout
ensure_workspace_dirs

if ! image_exists "$HERMES_IMAGE"; then
  if [[ "$TARGET_KIND" == "container" ]] && container_exists; then
    if container_running; then
      echo "==> Hermes Gateway container already running: $HERMES_CONTAINER_NAME"
      if [[ $# -gt 0 ]]; then
        exec env HERMES_WRAPPER_CONTEXT_OVERRIDE="$HERMES_WRAPPER_CONTEXT" HERMES_COMMITSTAMP_OVERRIDE="$HERMES_COMMITSTAMP" "$SCRIPT_DIR/hermes-open" "$WORKSPACE" "$LANE" "$REF" "$@"
      fi
      exit 0
    fi

    echo "==> Starting existing Hermes Gateway container without a matching local image tag: $HERMES_CONTAINER_NAME"
    podman start "$HERMES_CONTAINER_NAME" >/dev/null
    echo "==> Hermes Gateway container started: $HERMES_CONTAINER_NAME"
    if [[ $# -gt 0 ]]; then
      exec env HERMES_WRAPPER_CONTEXT_OVERRIDE="$HERMES_WRAPPER_CONTEXT" HERMES_COMMITSTAMP_OVERRIDE="$HERMES_COMMITSTAMP" "$SCRIPT_DIR/hermes-open" "$WORKSPACE" "$LANE" "$REF" "$@"
    fi
    exit 0
  fi
  fail "image not found: $HERMES_IMAGE (run hermes-build $LANE $REF first)"
fi

IMAGE_LANE="$(podman image inspect -f '{{index .Labels "hermes.lane"}}' "$HERMES_IMAGE" 2>/dev/null || echo "unknown")"
IMAGE_REF="$(podman image inspect -f '{{index .Labels "hermes.ref"}}' "$HERMES_IMAGE" 2>/dev/null || echo "unknown")"
IMAGE_FP="$(podman image inspect -f '{{index .Labels "hermes.wrapper_fingerprint"}}' "$HERMES_IMAGE" 2>/dev/null || echo "unknown")"

if container_exists; then
  if container_running; then
    CURRENT_IMG="$(container_image_id)"
    TARGET_IMG="$(image_id "$HERMES_IMAGE" 2>/dev/null || true)"
    if [[ "$CURRENT_IMG" == "$TARGET_IMG" ]]; then
      echo "==> Hermes Gateway container already running: $HERMES_CONTAINER_NAME"
      if [[ $# -gt 0 ]]; then
        exec env HERMES_WRAPPER_CONTEXT_OVERRIDE="$HERMES_WRAPPER_CONTEXT" HERMES_COMMITSTAMP_OVERRIDE="$HERMES_COMMITSTAMP" "$SCRIPT_DIR/hermes-open" "$WORKSPACE" "$LANE" "$REF" "$@"
      fi
      exit 0
    fi
    echo "==> Recreating running Hermes Gateway container with updated local image: $HERMES_CONTAINER_NAME"
    podman rm -f "$HERMES_CONTAINER_NAME" >/dev/null
  elif [[ "$(container_image_id)" != "$(image_id "$HERMES_IMAGE" 2>/dev/null || true)" ]]; then
    echo "==> Removing existing Hermes Gateway container with old image: $HERMES_CONTAINER_NAME"
    podman rm -f "$HERMES_CONTAINER_NAME" >/dev/null
  else
    echo "==> Starting existing stopped Hermes Gateway container: $HERMES_CONTAINER_NAME"
    podman start "$HERMES_CONTAINER_NAME" >/dev/null
    echo "==> Hermes Gateway container started: $HERMES_CONTAINER_NAME"
    if [[ $# -gt 0 ]]; then
      exec env HERMES_WRAPPER_CONTEXT_OVERRIDE="$HERMES_WRAPPER_CONTEXT" HERMES_COMMITSTAMP_OVERRIDE="$HERMES_COMMITSTAMP" "$SCRIPT_DIR/hermes-open" "$WORKSPACE" "$LANE" "$REF" "$@"
    fi
    exit 0
  fi
fi

echo "==> Starting Hermes Gateway container"
RUN_ARGS=(podman run -d \
  --name "$HERMES_CONTAINER_NAME" \
  --restart unless-stopped \
  -v "$HERMES_HOME_DIR:/opt/data" \
  -v "$HERMES_WORKSPACE_DIR:/workspace/hermes-workspace" \
  -w /workspace/hermes-workspace \
  --label "hermes.workspace=${WORKSPACE_NAME}" \
  --label "hermes.lane=${IMAGE_LANE}" \
  --label "hermes.ref=${IMAGE_REF}" \
  --label "hermes.wrapper_context=${HERMES_WRAPPER_CONTEXT}" \
  --label "hermes.commitstamp=${HERMES_COMMITSTAMP}" \
  -e "HERMES_BUILD_LANE=${IMAGE_LANE}" \
  -e "HERMES_BUILD_REF=${IMAGE_REF}" \
  -e "HERMES_BUILD_FINGERPRINT=${IMAGE_FP}")
RUN_ARGS+=("$HERMES_IMAGE" gateway run)
"${RUN_ARGS[@]}" >/dev/null
echo "==> Hermes Gateway container started: $HERMES_CONTAINER_NAME"

if [[ $# -gt 0 ]]; then
  exec env HERMES_WRAPPER_CONTEXT_OVERRIDE="$HERMES_WRAPPER_CONTEXT" HERMES_COMMITSTAMP_OVERRIDE="$HERMES_COMMITSTAMP" "$SCRIPT_DIR/hermes-open" "$WORKSPACE" "$LANE" "$REF" "$@"
fi
