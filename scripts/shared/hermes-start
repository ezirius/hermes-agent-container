#!/usr/bin/env bash
set -euo pipefail

SCRIPT_DIR="$(cd "$(dirname "$0")" && pwd)"
ROOT="$(cd "$SCRIPT_DIR/../.." && pwd)"
source "$ROOT/lib/shell/common.sh"

if [[ ${1-} == "--help" ]]; then
  show_help "Usage: $(basename "$0") [<workspace-name>] [hermes args...]
       $(basename "$0") [<workspace-name>] -- [hermes args...]
       $(basename "$0") [<workspace-name>] $(lane_usage_text) <upstream> [hermes args...]
       $(basename "$0") [<workspace-name>] $(lane_usage_text) <upstream> -- [hermes args...]
       $(basename "$0") -- $(lane_usage_text) <upstream> [hermes args...]

Start or reuse the Hermes Gateway container for one workspace.

Arguments:
- <workspace-name>           optional workspace name under HERMES_BASE_ROOT

Container naming:
  hermes-agent-<workspace>-<lane>-<upstream>-<wrapper>

The wrapper mounts:
- <workspace>/${HERMES_WORKSPACE_HOME_DIRNAME}      -> ${HERMES_CONTAINER_RUNTIME_HOME}
- <workspace>/${HERMES_WORKSPACE_DIRNAME} -> ${HERMES_CONTAINER_WORKSPACE_DIR}

The image uses an upstream-style entrypoint. Hermes reads ${HERMES_CONTAINER_RUNTIME_HOME}/.env and
${HERMES_CONTAINER_RUNTIME_HOME}/config.yaml when the gateway process starts. The container is created
with restart policy ${HERMES_CONTAINER_RESTART_POLICY} so crashes and host reboots recover
automatically.

Image naming:
  hermes-agent-local:<lane>-<upstream>-<wrapper>-<commitstamp>

Build labels (ref, lane, wrapper, fingerprint) are automatically injected from the image.

In explicit mode, the target image is resolved for the current wrapper context.

Use \`--\` when omitting the workspace and the next wrapper or forwarded argument
would otherwise be ambiguous."
fi

if [[ $# -gt 0 && "$1" != "--" ]]; then
  WORKSPACE="$(resolve_workspace_argument "$1")"
  shift
else
  WORKSPACE="$(resolve_workspace_argument '')"
  if [[ ${1-} == "--" ]]; then
    shift
  fi
fi

PAYLOAD_ONLY=0
if [[ ${1-} == "--" ]]; then
  shift
  PAYLOAD_ONLY=1
fi
TARGET_KIND="explicit"

require_podman

if [[ "$PAYLOAD_ONLY" == "0" && $# == 1 ]] && is_lane "$1"; then
  usage_error "$(basename "$0") [<workspace-name>] $(lane_usage_text) <upstream> [hermes args...]"
fi

if [[ "$PAYLOAD_ONLY" == "0" && $# -ge 2 ]] && is_lane "$1"; then
  LANE="$1"
  REF="$2"
  shift 2
  if [[ ${1-} == "--" ]]; then
    shift
  fi
  resolve_start_target "$WORKSPACE" "$LANE" "$REF"
else
  TARGET_ROW="$(pick_workspace_target "$WORKSPACE" target)"
  IFS=$'\t' read -r TARGET_KIND _ LANE REF HERMES_WRAPPER_CONTEXT HERMES_COMMITSTAMP _ <<< "$TARGET_ROW"
  resolve_start_target "$WORKSPACE" "$LANE" "$REF" "$HERMES_WRAPPER_CONTEXT" "$HERMES_COMMITSTAMP"
fi

validate_lane "$LANE"
validate_upstream_selector "$REF"

ensure_workspace_dirs
migrate_legacy_workspace_layout
ensure_workspace_dirs

if ! image_exists "$HERMES_IMAGE"; then
  if container_exists; then
    if container_running; then
      echo "==> Hermes Gateway container already running: $HERMES_CONTAINER_NAME"
      if [[ $# -gt 0 ]]; then
        exec env HERMES_WRAPPER_CONTEXT_OVERRIDE="$HERMES_WRAPPER_CONTEXT" HERMES_COMMITSTAMP_OVERRIDE="$HERMES_COMMITSTAMP" "$SCRIPT_DIR/hermes-open" "$WORKSPACE" "$LANE" "$REF" "$@"
      fi
      exit 0
    fi

    echo "==> Starting existing Hermes Gateway container without a matching local image tag: $HERMES_CONTAINER_NAME"
    podman start "$HERMES_CONTAINER_NAME" >/dev/null
    echo "==> Hermes Gateway container started: $HERMES_CONTAINER_NAME"
    if [[ $# -gt 0 ]]; then
      exec env HERMES_WRAPPER_CONTEXT_OVERRIDE="$HERMES_WRAPPER_CONTEXT" HERMES_COMMITSTAMP_OVERRIDE="$HERMES_COMMITSTAMP" "$SCRIPT_DIR/hermes-open" "$WORKSPACE" "$LANE" "$REF" "$@"
    fi
    exit 0
  fi
  fail "image not found: $HERMES_IMAGE (run hermes-build $LANE $REF first)"
fi

IMAGE_LANE="$(podman image inspect -f "{{index .Labels \"$HERMES_LABEL_LANE\"}}" "$HERMES_IMAGE" 2>/dev/null || echo "unknown")"
IMAGE_REF="$(podman image inspect -f "{{index .Labels \"$HERMES_LABEL_UPSTREAM\"}}" "$HERMES_IMAGE" 2>/dev/null || echo "unknown")"
IMAGE_FP="$(podman image inspect -f "{{index .Labels \"$(hermes_build_fingerprint_label_key)\"}}" "$HERMES_IMAGE" 2>/dev/null || echo "unknown")"

if [[ "$IMAGE_LANE" == "unknown" || "$IMAGE_REF" == "unknown" || "$IMAGE_FP" == "unknown" ]]; then
  fail "image metadata is missing required Hermes labels: $HERMES_IMAGE"
fi

if container_exists; then
  if container_running; then
    CURRENT_IMG="$(container_image_id)"
    TARGET_IMG="$(image_id "$HERMES_IMAGE" 2>/dev/null || true)"
    if [[ "$CURRENT_IMG" == "$TARGET_IMG" ]]; then
      echo "==> Hermes Gateway container already running: $HERMES_CONTAINER_NAME"
      if [[ $# -gt 0 ]]; then
        exec env HERMES_WRAPPER_CONTEXT_OVERRIDE="$HERMES_WRAPPER_CONTEXT" HERMES_COMMITSTAMP_OVERRIDE="$HERMES_COMMITSTAMP" "$SCRIPT_DIR/hermes-open" "$WORKSPACE" "$LANE" "$REF" "$@"
      fi
      exit 0
    fi
    echo "==> Recreating running Hermes Gateway container with updated local image: $HERMES_CONTAINER_NAME"
    podman rm -f "$HERMES_CONTAINER_NAME" >/dev/null
  elif [[ "$(container_image_id)" != "$(image_id "$HERMES_IMAGE" 2>/dev/null || true)" ]]; then
    echo "==> Removing existing Hermes Gateway container with old image: $HERMES_CONTAINER_NAME"
    podman rm -f "$HERMES_CONTAINER_NAME" >/dev/null
  else
    echo "==> Starting existing stopped Hermes Gateway container: $HERMES_CONTAINER_NAME"
    podman start "$HERMES_CONTAINER_NAME" >/dev/null
    echo "==> Hermes Gateway container started: $HERMES_CONTAINER_NAME"
    if [[ $# -gt 0 ]]; then
      exec env HERMES_WRAPPER_CONTEXT_OVERRIDE="$HERMES_WRAPPER_CONTEXT" HERMES_COMMITSTAMP_OVERRIDE="$HERMES_COMMITSTAMP" "$SCRIPT_DIR/hermes-open" "$WORKSPACE" "$LANE" "$REF" "$@"
    fi
    exit 0
  fi
fi

echo "==> Starting Hermes Gateway container"
RUN_ARGS=(podman run -d \
  --name "$HERMES_CONTAINER_NAME" \
  --restart "$(container_restart_policy)" \
  -v "$HERMES_HOME_DIR:$HERMES_CONTAINER_RUNTIME_HOME" \
  -v "$HERMES_WORKSPACE_DIR:$HERMES_CONTAINER_WORKSPACE_DIR" \
  -w "$HERMES_CONTAINER_WORKSPACE_DIR" \
  --label "${HERMES_LABEL_WORKSPACE}=${WORKSPACE_NAME}" \
  --label "${HERMES_LABEL_LANE}=${IMAGE_LANE}" \
  --label "${HERMES_LABEL_UPSTREAM}=${IMAGE_REF}" \
  --label "${HERMES_LABEL_WRAPPER}=${HERMES_WRAPPER_CONTEXT}" \
  --label "${HERMES_LABEL_COMMITSTAMP}=${HERMES_COMMITSTAMP}" \
  -e "HERMES_BUILD_LANE=${IMAGE_LANE}" \
  -e "HERMES_BUILD_REF=${IMAGE_REF}" \
  -e "HERMES_BUILD_FINGERPRINT=${IMAGE_FP}")
RUN_ARGS+=("$HERMES_IMAGE" gateway run)
"${RUN_ARGS[@]}" >/dev/null
echo "==> Hermes Gateway container started: $HERMES_CONTAINER_NAME"

if [[ $# -gt 0 ]]; then
  exec env HERMES_WRAPPER_CONTEXT_OVERRIDE="$HERMES_WRAPPER_CONTEXT" HERMES_COMMITSTAMP_OVERRIDE="$HERMES_COMMITSTAMP" "$SCRIPT_DIR/hermes-open" "$WORKSPACE" "$LANE" "$REF" "$@"
fi
