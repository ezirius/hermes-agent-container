#!/usr/bin/env bash
set -euo pipefail

SCRIPT_DIR="$(cd "$(dirname "$0")" && pwd)"
ROOT="$(cd "$SCRIPT_DIR/../.." && pwd)"
source "$ROOT/lib/shell/common.sh"

if [[ $# -ne 1 ]]; then
  usage_error "$(basename "$0") requires exactly 1 argument: <workspace-name>"
fi

require_podman
resolve_workspace "$1"
ensure_workspace_dirs

if ! image_exists; then
  fail "image not found: $HERMES_IMAGE_NAME (run $SCRIPT_DIR/hermes-build first)"
fi

if container_exists; then
  if container_running; then
    if [[ "$(container_image_id)" == "$(image_id)" ]]; then
      echo "==> Hermes container already running: $HERMES_CONTAINER_NAME"
      exit 0
    fi
    echo "==> Recreating running container with updated local image: $HERMES_CONTAINER_NAME"
    podman rm -f "$HERMES_CONTAINER_NAME" >/dev/null
  elif [[ "$(container_image_id)" != "$(image_id)" ]]; then
    echo "==> Removing existing container with old image: $HERMES_CONTAINER_NAME"
    podman rm -f "$HERMES_CONTAINER_NAME" >/dev/null
  else
    echo "==> Starting existing stopped container: $HERMES_CONTAINER_NAME"
    podman start "$HERMES_CONTAINER_NAME" >/dev/null
    echo "==> Hermes container started: $HERMES_CONTAINER_NAME"
    exit 0
  fi
fi

echo "==> Starting Hermes container"
podman run -d \
  --name "$HERMES_CONTAINER_NAME" \
  -v "$WORKSPACE_ROOT:/data" \
  -v "$HERMES_WORKSPACE_DIR:/workspace" \
  -w /workspace \
  "$HERMES_IMAGE_NAME" >/dev/null
echo "==> Hermes container started: $HERMES_CONTAINER_NAME"
