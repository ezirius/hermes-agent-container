#!/usr/bin/env bash
set -euo pipefail

SCRIPT_DIR="$(cd "$(dirname "$0")" && pwd)"
ROOT="$(cd "$SCRIPT_DIR/../.." && pwd)"
source "$ROOT/lib/shell/common.sh"

if [[ ${1-} == "--help" ]]; then
  show_help "Usage: $(basename "$0") <workspace-name>

Show a concise Hermes Gateway container status summary for one workspace.

Arguments:
- <workspace-name>           required workspace name under HERMES_BASE_ROOT"
fi

if [[ $# -ne 1 ]]; then
  usage_error "$(basename "$0") requires exactly 1 argument: <workspace-name>"
fi

WORKSPACE="$1"

require_workspace_name "$WORKSPACE"

require_podman
TARGET_ROW="$(pick_workspace_target "$WORKSPACE" container)"
IFS=$'\t' read -r _ HERMES_CONTAINER_NAME _ _ _ _ _ <<< "$TARGET_ROW"

container_exists || fail "container not found: $HERMES_CONTAINER_NAME"
status_summary "$HERMES_CONTAINER_NAME"
