#!/usr/bin/env bash
set -euo pipefail

SCRIPT_DIR="$(cd "$(dirname "$0")" && pwd)"
ROOT="$(cd "$SCRIPT_DIR/../.." && pwd)"
source "$ROOT/lib/shell/common.sh"

if [[ ${1-} == "--help" ]]; then
  show_help "Usage: $(basename "$0") <workspace-name> [hermes args...]

Start Hermes for one workspace by selecting an existing project target.

This command does not auto-build or auto-upgrade images. Build the desired
immutable image first with hermes-build, then use hermes-bootstrap to start/open the
matching target.

Arguments:
- <workspace-name>           required workspace name under HERMES_BASE_ROOT

Common forwarded Hermes args:
- setup                     run the setup wizard
- model                     choose provider and model
- tools                     configure enabled tools
- doctor                    diagnose local problems
- gateway                   run gateway subcommands
- chat                      open the interactive chat mode"
fi

if [[ $# -lt 1 ]]; then
  usage_error "$(basename "$0") requires at least 1 argument: <workspace-name> [hermes args...]"
fi

WORKSPACE="$1"
shift 1

require_workspace_name "$WORKSPACE"

TARGET_ROW="$(pick_workspace_target "$WORKSPACE" target)"
IFS=$'\t' read -r _ _ LANE REF WRAPPER COMMITSTAMP _ <<< "$TARGET_ROW"

env HERMES_WRAPPER_CONTEXT_OVERRIDE="$WRAPPER" HERMES_COMMITSTAMP_OVERRIDE="$COMMITSTAMP" \
  "$SCRIPT_DIR/hermes-start" "$WORKSPACE" "$LANE" "$REF"
exec env HERMES_WRAPPER_CONTEXT_OVERRIDE="$WRAPPER" HERMES_COMMITSTAMP_OVERRIDE="$COMMITSTAMP" \
  "$SCRIPT_DIR/hermes-open" "$WORKSPACE" "$LANE" "$REF" "$@"
