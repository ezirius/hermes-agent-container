#!/usr/bin/env bash
set -euo pipefail

SCRIPT_DIR="$(cd "$(dirname "$0")" && pwd)"
ROOT="$(cd "$SCRIPT_DIR/../.." && pwd)"
source "$ROOT/lib/shell/common.sh"

if [[ ${1-} == "--help" ]]; then
  show_help "Usage: $(basename "$0") <workspace-name> [command args...]

Open an interactive shell by execing into the running Hermes Gateway container.

Arguments:
- <workspace-name>           required workspace name under HERMES_BASE_ROOT"
fi

if [[ $# -lt 1 ]]; then
  usage_error "$(basename "$0") requires at least 1 argument: <workspace-name> [command args...]"
fi

WORKSPACE="$1"
shift 1

require_workspace_name "$WORKSPACE"

require_podman
TARGET_ROW="$(pick_workspace_target "$WORKSPACE" container)"
IFS=$'\t' read -r _ HERMES_CONTAINER_NAME _ _ _ _ _ <<< "$TARGET_ROW"

container_exists || fail "container not found: $HERMES_CONTAINER_NAME"
container_running || fail "container not running: $HERMES_CONTAINER_NAME (run hermes-start first)"

if [[ $# -gt 0 ]]; then
  RUN_ARGS=(--workdir /workspace/hermes-workspace "$HERMES_CONTAINER_NAME" "$@")
else
  RUN_ARGS=(--workdir /workspace/hermes-workspace "$HERMES_CONTAINER_NAME" /bin/bash)
fi
exec_podman_interactive_command exec "${RUN_ARGS[@]}"
