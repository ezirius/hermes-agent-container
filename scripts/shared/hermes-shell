#!/usr/bin/env bash
set -euo pipefail

SCRIPT_DIR="$(cd "$(dirname "$0")" && pwd)"
ROOT="$(cd "$SCRIPT_DIR/../.." && pwd)"
source "$ROOT/lib/shell/common.sh"

if [[ ${1-} == "--help" ]]; then
  show_help "Usage: $(basename "$0") <workspace-name>

Open an interactive shell by execing into the running Hermes Gateway container
for one workspace."
fi

if [[ $# -ne 1 ]]; then
  usage_error "$(basename "$0") requires exactly 1 argument: <workspace-name>"
fi

require_podman
resolve_workspace "$1"
container_exists || fail "container not found: $HERMES_CONTAINER_NAME (run $SCRIPT_DIR/hermes-start first)"
container_running || fail "container not running: $HERMES_CONTAINER_NAME (run $SCRIPT_DIR/hermes-start first)"
if [[ "$(container_image_id)" != "$(image_id)" ]]; then
  echo "==> Workspace container image is stale; reconciling with the current shared image"
  "$SCRIPT_DIR/hermes-start" "$WORKSPACE_NAME" >/dev/null
fi
exec_podman_interactive_command exec \
  --workdir /workspace \
  "$HERMES_CONTAINER_NAME" \
  /bin/bash
