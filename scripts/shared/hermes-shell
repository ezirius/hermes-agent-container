#!/usr/bin/env bash
set -euo pipefail

SCRIPT_DIR="$(cd "$(dirname "$0")" && pwd)"
ROOT="$(cd "$SCRIPT_DIR/../.." && pwd)"
source "$ROOT/lib/shell/common.sh"

if [[ ${1-} == "--help" ]]; then
  show_help "Usage: $(basename "$0") [<workspace-name>] [command args...]
       $(basename "$0") [<workspace-name>] -- [command args...]
       $(basename "$0") [<workspace-name>] $(lane_usage_text) <upstream> [command args...]
       $(basename "$0") [<workspace-name>] $(lane_usage_text) <upstream> -- [command args...]
       $(basename "$0") -- $(lane_usage_text) <upstream> [command args...]

Open an interactive shell by execing into the running Hermes Gateway container.

Arguments:
- <workspace-name>           optional workspace name under HERMES_BASE_ROOT"
fi

if [[ $# -gt 0 && "$1" != "--" ]]; then
  WORKSPACE="$(resolve_workspace_argument "$1")"
  shift
else
  WORKSPACE="$(resolve_workspace_argument '')"
  if [[ ${1-} == "--" ]]; then
    shift
  fi
fi

require_podman

PAYLOAD_ONLY=0
if [[ ${1-} == "--" ]]; then
  shift
  PAYLOAD_ONLY=1
fi

if [[ "$PAYLOAD_ONLY" == "0" && $# == 1 ]] && is_lane "$1"; then
  usage_error "$(basename "$0") [<workspace-name>] $(lane_usage_text) <upstream> [command args...]"
fi

if [[ "$PAYLOAD_ONLY" == "0" && $# -ge 2 ]] && is_lane "$1"; then
  LANE="$1"
  REF="$2"
  shift 2
  if [[ ${1-} == "--" ]]; then
    shift
  fi
  resolve_build_target "$WORKSPACE" "$LANE" "$REF"
else
  TARGET_ROW="$(pick_workspace_target "$WORKSPACE" container)"
  IFS=$'\t' read -r _ HERMES_CONTAINER_NAME _ _ _ _ _ <<< "$TARGET_ROW"
fi

container_exists || fail "container not found: $HERMES_CONTAINER_NAME"
container_running || fail "container not running: $HERMES_CONTAINER_NAME (run hermes-start first)"

if [[ $# -gt 0 ]]; then
  RUN_ARGS=(--workdir "$HERMES_CONTAINER_WORKSPACE_DIR" "$HERMES_CONTAINER_NAME" "$@")
else
  RUN_ARGS=(--workdir "$HERMES_CONTAINER_WORKSPACE_DIR" "$HERMES_CONTAINER_NAME" /bin/bash)
fi
exec_podman_interactive_command exec "${RUN_ARGS[@]}"
