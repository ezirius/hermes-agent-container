#!/usr/bin/env bash
set -euo pipefail

SCRIPT_DIR="$(cd "$(dirname "$0")" && pwd)"
ROOT="$(cd "$SCRIPT_DIR/../.." && pwd)"
source "$ROOT/lib/shell/common.sh"

if [[ ${1-} == "--help" ]]; then
  show_help "Usage: $(basename "$0") <workspace-name>

Remove the Hermes Gateway container for one workspace.

This removes the container only. Persistent workspace data under HERMES_BASE_ROOT
is left intact."
fi

if [[ $# -ne 1 ]]; then
  usage_error "$(basename "$0") requires exactly 1 argument: <workspace-name>"
fi

require_podman
resolve_workspace "$1"

if container_exists; then
  echo "==> Removing Hermes container: $HERMES_CONTAINER_NAME"
  podman rm -f "$HERMES_CONTAINER_NAME" >/dev/null
else
  echo "==> No container found: $HERMES_CONTAINER_NAME"
fi
