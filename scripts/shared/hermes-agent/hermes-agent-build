#!/usr/bin/env bash

set -euo pipefail

# This script builds a fresh Hermes Agent image from the saved repo settings.

# This finds the repo root so the script can reach shared helpers and config.
SCRIPT_DIR="$(cd "$(dirname "$0")" && pwd)"
ROOT="$(cd "$SCRIPT_DIR/../../.." && pwd)"
source "$ROOT/scripts/shared/hermes-agent/common.sh"

# This prints the build usage in the shared family style.
print_help() {
  printf 'Usage: scripts/shared/hermes-agent/hermes-agent-build\n'
  printf 'This script takes no arguments. See --help.\n'
}

# This keeps the build entrypoint simple and predictable.
if [[ $# -gt 0 ]]; then
  if [[ "$1" == '--help' ]]; then
    print_help
    exit 0
  fi

  printf 'This script takes no arguments. See --help.\n' >&2
  exit 1
fi

# This stops the build if the checkout is not fully committed and clean.
hermes_warn_if_pinned_version_is_stale
hermes_require_clean_committed_checkout "$ROOT"

# This makes a unique image name so each successful build can be found later.
timestamp="$(/bin/date +"%Y%m%d-%H%M%S")"
temporary_image_name="$HERMES_AGENT_IMAGE_BASENAME-$HERMES_AGENT_VERSION-$timestamp-$$"

# This removes the temporary image tag after success and on post-build failures.
cleanup_temporary_image() {
  podman rmi "$temporary_image_name" >/dev/null 2>&1 || true
}

trap cleanup_temporary_image EXIT

# This lets Podman stream its normal build output while saving the final image id for later.
podman build \
  --arch "$HERMES_AGENT_TARGET_ARCH" \
  --build-arg HERMES_AGENT_UPSTREAM_IMAGE="$HERMES_AGENT_UPSTREAM_IMAGE" \
  --build-arg HERMES_AGENT_RELEASE_TAG="$HERMES_AGENT_RELEASE_TAG" \
  --build-arg HERMES_AGENT_NUSHELL_FALLBACK_VERSION="$HERMES_AGENT_NUSHELL_FALLBACK_VERSION" \
  --build-arg HERMES_AGENT_NUSHELL_FALLBACK_SHA256_AARCH64="$HERMES_AGENT_NUSHELL_FALLBACK_SHA256_AARCH64" \
  --build-arg HERMES_AGENT_NUSHELL_FALLBACK_SHA256_X86_64="$HERMES_AGENT_NUSHELL_FALLBACK_SHA256_X86_64" \
  --build-arg HERMES_AGENT_CONTAINER_DOCS="$HERMES_AGENT_CONTAINER_DOCS" \
  -f "$ROOT/configs/shared/hermes-agent/Containerfile" \
  -t "$temporary_image_name" \
  "$ROOT"

# This folds the content image id into the final local image name.
image_id="$(podman image inspect --format '{{.Id}}' "$temporary_image_name")"
image_short_id="${image_id#sha256:}"
image_short_id="${image_short_id:0:12}"
image_name="$HERMES_AGENT_IMAGE_BASENAME-$HERMES_AGENT_VERSION-$timestamp-$image_short_id"
podman tag "$temporary_image_name" "$image_name"
trap - EXIT
cleanup_temporary_image

printf 'Built image: %s\n' "$image_name"
