# This image consumes shared config via build args and keeps the runtime contract in env vars.
ARG HERMES_AGENT_NODE_IMAGE
ARG HERMES_AGENT_RUNTIME_IMAGE

FROM ${HERMES_AGENT_NODE_IMAGE} AS hermes-web-builder

# This stage builds the upstream Hermes frontend so the runtime install can package web_dist.
ARG HERMES_AGENT_RELEASE_TAG

RUN apt-get update && apt-get install -y --no-install-recommends \
    ca-certificates \
    curl \
    tar \
    && rm -rf /var/lib/apt/lists/*

WORKDIR /opt/hermes-src

RUN curl -fsSL "https://github.com/NousResearch/hermes-agent/archive/refs/tags/${HERMES_AGENT_RELEASE_TAG}.tar.gz" -o /tmp/hermes-agent.tar.gz \
    && tar -xzf /tmp/hermes-agent.tar.gz --strip-components=1 -C /opt/hermes-src \
    && rm -f /tmp/hermes-agent.tar.gz

WORKDIR /opt/hermes-src/web

RUN npm ci \
    && npm run build

FROM ${HERMES_AGENT_RUNTIME_IMAGE}

# Build args mirror the shared config so the image shape stays config-driven.
ARG HERMES_AGENT_UID
ARG HERMES_AGENT_GID
ARG HERMES_AGENT_RELEASE_TAG
ARG HERMES_AGENT_DASHBOARD_PORT
ARG HERMES_AGENT_CONTAINER_HOME
ARG HERMES_AGENT_CONTAINER_WORKSPACE

# These env vars define the runtime locations Hermes expects after the host mounts are attached.
ENV DEBIAN_FRONTEND=noninteractive \
    PATH="/opt/hermes-venv/bin:${PATH}" \
    HOME=${HERMES_AGENT_CONTAINER_HOME} \
    HERMES_AGENT_DASHBOARD_PORT=${HERMES_AGENT_DASHBOARD_PORT} \
    HERMES_BUNDLED_SKILLS=/opt/hermes-src/skills \
    HERMES_HOME=${HERMES_AGENT_CONTAINER_HOME}/.hermes \
    HERMES_WORKSPACE=${HERMES_AGENT_CONTAINER_WORKSPACE}

# Install the base packages needed for the upstream full install flow and keep PID 1 well-behaved.
RUN apt-get update && apt-get install -y --no-install-recommends \
    bash \
    ca-certificates \
    curl \
    ffmpeg \
    git \
    libolm-dev \
    python3 \
    python3-pip \
    python3-venv \
    ripgrep \
    tar \
    tini \
    && rm -rf /var/lib/apt/lists/*

# The container user and writable directories must match the host-mounted paths from config.
# If the requested gid already exists in the base image, reuse that group instead of failing.
RUN container_group_name="$(getent group "${HERMES_AGENT_GID}" | cut -d: -f1 || true)" \
    && if [ -z "${container_group_name}" ]; then \
         groupadd --gid "${HERMES_AGENT_GID}" hermes-agent; \
         container_group_name="hermes-agent"; \
       fi \
    && useradd --uid "${HERMES_AGENT_UID}" --gid "${container_group_name}" --create-home --home-dir "${HERMES_AGENT_CONTAINER_HOME}" --shell /bin/bash hermes-agent \
    && mkdir -p "${HERMES_AGENT_CONTAINER_HOME}/.hermes" "${HERMES_AGENT_CONTAINER_WORKSPACE}" \
    && chown -R hermes-agent:"${container_group_name}" "${HERMES_AGENT_CONTAINER_HOME}" "${HERMES_AGENT_CONTAINER_WORKSPACE}"

# Hermes follows the upstream full install flow with uv, Python 3.11, and a source-tree install.
RUN curl -LsSf https://astral.sh/uv/install.sh | sh \
    && export PATH="${HERMES_AGENT_CONTAINER_HOME}/.local/bin:${PATH}" \
    && export UV_PYTHON_INSTALL_DIR="/opt/hermes-python" \
    && uv python install 3.11 \
    && uv venv /opt/hermes-venv --python 3.11 \
    && mkdir -p /opt/hermes-src \
    && curl -fsSL "https://github.com/NousResearch/hermes-agent/archive/refs/tags/${HERMES_AGENT_RELEASE_TAG}.tar.gz" -o /tmp/hermes-agent.tar.gz \
    && tar -xzf /tmp/hermes-agent.tar.gz --strip-components=1 -C /opt/hermes-src \
    && rm -f /tmp/hermes-agent.tar.gz

# Copy the built frontend into the source tree before install so Hermes packages web_dist.
COPY --from=hermes-web-builder /opt/hermes-src/hermes_cli/web_dist /opt/hermes-src/hermes_cli/web_dist

# Apply the backport from the extracted Hermes source tree before installation.
WORKDIR /opt/hermes-src

RUN git apply <<'HERMES_MATRIX_DEVICE_BACKPORT'
diff --git a/gateway/platforms/matrix.py b/gateway/platforms/matrix.py
