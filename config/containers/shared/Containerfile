HERMES_MATRIX_DEVICE_BACKPORT

RUN export PATH="${HERMES_AGENT_CONTAINER_HOME}/.local/bin:${PATH}" \
    && export VIRTUAL_ENV="/opt/hermes-venv" \
    && uv pip install "/opt/hermes-src[all]" \
    && test -f /opt/hermes-src/tools/skills_sync.py \
    && container_group_name="$(getent group "${HERMES_AGENT_GID}" | cut -d: -f1)" \
    && chown -R hermes-agent:"${container_group_name}" /opt/hermes-venv

# Copy the repo entrypoint into a stable runtime location.
COPY scripts/agent/shared/hermes-agent-entrypoint /usr/local/bin/hermes-agent-entrypoint

RUN chmod +x /usr/local/bin/hermes-agent-entrypoint

# WORKDIR must follow the shared config so host workspace mounts land at the active shell location.
USER hermes-agent
WORKDIR ${HERMES_AGENT_CONTAINER_WORKSPACE}

# Expose the same dashboard port the host run script publishes.
EXPOSE ${HERMES_AGENT_DASHBOARD_PORT}

# Tini remains PID 1 and hands off to the repo entrypoint for setup-aware service startup.
ENTRYPOINT ["/usr/bin/tini", "--", "/usr/local/bin/hermes-agent-entrypoint"]
CMD []
