ARG UBUNTU_VERSION
ARG HERMES_CONTAINER_WORKSPACE_DIR
ARG HERMES_CONTAINER_RUNTIME_HOME
FROM ubuntu:${UBUNTU_VERSION}

ARG HERMES_CONTAINER_WORKSPACE_DIR
ARG HERMES_CONTAINER_RUNTIME_HOME

ARG NODE_LTS_VERSION
ARG HERMES_REPO_URL
ARG HERMES_REF
ARG HERMES_WRAPPER_LANE
ARG HERMES_WRAPPER_UPSTREAM
ARG HERMES_WRAPPER_UPSTREAM_REF
ARG HERMES_WRAPPER_CONTEXT
ARG HERMES_WRAPPER_COMMITSTAMP

ENV DEBIAN_FRONTEND=noninteractive
ENV TZ=UTC
ENV LANG=C.UTF-8
ENV LC_ALL=C.UTF-8

RUN apt-get update \
  && apt-get install -y --no-install-recommends \
    bash \
    build-essential \
    ca-certificates \
    curl \
    ffmpeg \
    gcc \
    git \
    gnupg \
    libffi-dev \
    libolm-dev \
    python3 \
    python3-dev \
    python3-pip \
    ripgrep \
    tini \
  && rm -rf /var/lib/apt/lists/* \
  && useradd -m -s /bin/bash hermes \
  && workspace_parent="$(dirname "${HERMES_CONTAINER_WORKSPACE_DIR}")" \
  && mkdir -p "$workspace_parent" "${HERMES_CONTAINER_WORKSPACE_DIR}" "${HERMES_CONTAINER_RUNTIME_HOME}" \
  && chown -R root:root "$workspace_parent" \
  && chown -R hermes:hermes "${HERMES_CONTAINER_WORKSPACE_DIR}" "${HERMES_CONTAINER_RUNTIME_HOME}"

RUN mkdir -p /etc/apt/keyrings \
  && curl -fsSL "https://deb.nodesource.com/gpgkey/nodesource-repo.gpg.key" | gpg --dearmor -o /etc/apt/keyrings/nodesource.gpg \
  && echo "deb [signed-by=/etc/apt/keyrings/nodesource.gpg] https://deb.nodesource.com/node_${NODE_LTS_VERSION}.x nodistro main" > /etc/apt/sources.list.d/nodesource.list \
  && apt-get update \
  && apt-get install -y --no-install-recommends nodejs \
  && rm -rf /var/lib/apt/lists/*

COPY config/patches /tmp/hermes-patches
COPY config/containers/entrypoint.sh /usr/local/bin/hermes-entrypoint.sh

RUN chmod 755 /usr/local/bin/hermes-entrypoint.sh

WORKDIR /home/hermes

RUN test -n "$HERMES_REF" \
  || (echo >&2 "HERMES_REF must be set to a real upstream tag or branch before building" && exit 1)

RUN git clone --depth 1 --branch "$HERMES_REF" "$HERMES_REPO_URL" /home/hermes/hermes-agent \
  && python3 /tmp/hermes-patches/apply-hermes-host-agents-context.py \
  && python3 /tmp/hermes-patches/apply-hermes-matrix-device-id.py \
  && python3 /tmp/hermes-patches/apply-hermes-matrix-config-overrides.py \
  && python3 /tmp/hermes-patches/apply-hermes-transcription-oga.py \
  && python3 -m pip install -e "/home/hermes/hermes-agent[all]" --break-system-packages \
  && python3 -m pip install -e "/home/hermes/hermes-agent[matrix]" --break-system-packages \
  && cd /home/hermes/hermes-agent \
  && npm install --prefer-offline --no-audit \
  && npx playwright install --with-deps chromium --only-shell \
   && cd /home/hermes/hermes-agent/scripts/whatsapp-bridge \
   && npm install --prefer-offline --no-audit \
   && npm cache clean --force \
   && chown -R hermes:hermes /home/hermes

ENV HERMES_HOME=${HERMES_CONTAINER_RUNTIME_HOME}
ENV HERMES_CONTAINER_RUNTIME_HOME=${HERMES_CONTAINER_RUNTIME_HOME}
ENV HERMES_CONTAINER_WORKSPACE_DIR=${HERMES_CONTAINER_WORKSPACE_DIR}
ENV INSTALL_DIR=/home/hermes/hermes-agent
ENV HOME=${HERMES_CONTAINER_RUNTIME_HOME}

USER hermes
WORKDIR ${HERMES_CONTAINER_WORKSPACE_DIR}

ENTRYPOINT ["/usr/bin/tini", "--", "/usr/local/bin/hermes-entrypoint.sh"]
CMD ["sleep", "infinity"]
