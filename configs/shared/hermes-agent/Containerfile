# This image derives from the official Hermes Agent container and adds repo-local tools.
ARG HERMES_AGENT_UPSTREAM_IMAGE
ARG HERMES_AGENT_RELEASE_TAG
ARG HERMES_AGENT_NUSHELL_FALLBACK_VERSION
ARG HERMES_AGENT_NUSHELL_FALLBACK_SHA256_AARCH64
ARG HERMES_AGENT_NUSHELL_FALLBACK_SHA256_X86_64

FROM ${HERMES_AGENT_UPSTREAM_IMAGE}:${HERMES_AGENT_RELEASE_TAG}

ARG HERMES_AGENT_CONTAINER_DOCS

# Install only the local shell customization; upstream starts as root so its entrypoint can drop privileges.
USER root
RUN apt-get update \
  && apt-get install -y --no-install-recommends ca-certificates curl tar \
  && if apt-cache show nushell >/dev/null 2>&1; then \
        apt-get install -y --no-install-recommends nushell; \
      else \
        arch="$(dpkg --print-architecture)"; \
        case "$arch" in \
          amd64) nushell_arch='x86_64-unknown-linux-gnu'; nushell_sha256="$HERMES_AGENT_NUSHELL_FALLBACK_SHA256_X86_64" ;; \
          arm64) nushell_arch='aarch64-unknown-linux-gnu'; nushell_sha256="$HERMES_AGENT_NUSHELL_FALLBACK_SHA256_AARCH64" ;; \
          *) printf 'Unsupported Nushell architecture: %s\n' "$arch" >&2; exit 1 ;; \
        esac; \
        nushell_url="https://github.com/nushell/nushell/releases/download/${HERMES_AGENT_NUSHELL_FALLBACK_VERSION}/nu-${HERMES_AGENT_NUSHELL_FALLBACK_VERSION}-${nushell_arch}.tar.gz"; \
        curl -fsSL "$nushell_url" -o /tmp/nushell.tar.gz; \
        printf '%s  %s\n' "$nushell_sha256" /tmp/nushell.tar.gz | sha256sum -c -; \
        tar -xzf /tmp/nushell.tar.gz -C /tmp; \
        install "/tmp/nu-${HERMES_AGENT_NUSHELL_FALLBACK_VERSION}-${nushell_arch}/nu" /usr/local/bin/nu; \
        install "/tmp/nu-${HERMES_AGENT_NUSHELL_FALLBACK_VERSION}-${nushell_arch}/nu_plugin_"* /usr/local/bin/; \
        rm -rf /tmp/nushell.tar.gz "/tmp/nu-${HERMES_AGENT_NUSHELL_FALLBACK_VERSION}-${nushell_arch}"; \
      fi \
  && rm -rf /var/lib/apt/lists/*

WORKDIR ${HERMES_AGENT_CONTAINER_DOCS}
